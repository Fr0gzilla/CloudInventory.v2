FLASK_ENV=development
SECRET_KEY=change-me-in-production
DATABASE_URL=sqlite:///cloudinventory.db

# Auth (le mot de passe peut être un hash werkzeug : pbkdf2:sha256:...)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin

# JWT
JWT_EXPIRATION_HOURS=1

# Pagination
PER_PAGE=25

# NetBox
NETBOX_URL=http://127.0.0.1:8000
NETBOX_TOKEN=nbt_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NETBOX_VERIFY_SSL=false

# Sources de données (true = mock, false = API réelle)
USE_MOCK_VIRT=true
USE_MOCK_IPAM=true

# Proxmox VE
PROXMOX_URL=https://pve.local:8006
PROXMOX_TOKEN_ID=user@pam!token
PROXMOX_TOKEN_SECRET=xxxx
PROXMOX_VERIFY_SSL=false

# Webhook de notification (URL appelée après chaque run avec anomalies)
WEBHOOK_URL=

# Notification email SMTP (envoi d'un récapitulatif après chaque run avec anomalies)
SMTP_ENABLED=false
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USE_TLS=true
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=cloudinventory@example.com
SMTP_TO=admin@example.com

# Exports (stockage consolidé, rapport, bruts)
EXPORT_ENABLED=true
EXPORT_LOCAL_PATH=exports
EXPORT_SMB_PATH=
EXPORT_RETENTION_CONSOLIDATED=30
EXPORT_RETENTION_RAW=7
EXPORT_RAW_ENABLED=false
